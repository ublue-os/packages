Subject: [PATCH] use Aurora default wallpaper

This ensures that Plasma Setup starts up with our default wallpapers
---
 src/qml/LandingComponent.qml | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/src/qml/LandingComponent.qml b/src/qml/LandingComponent.qml
index fec30ab..8e0903e 100644
--- a/src/qml/LandingComponent.qml
+++ b/src/qml/LandingComponent.qml
@@ -43,11 +43,11 @@ Item {
         readonly property bool isLandscape: width >= height

         source: {
-            const landscapeFile = "5120x2880.png";
+            const landscapeFile = "3840x2160.jxl";
             const portraitFile  = "1440x2960.png";

-            const lightFolder = "wallpapers/Next/contents/images/";
-            const darkFolder  = "wallpapers/Next/contents/images_dark/";
+            const lightFolder = "wallpapers/Aurora/contents/images/";
+            const darkFolder  = "wallpapers/Aurora/contents/images/";
             const themedFolder = Prepare.PrepareUtil.usingDarkTheme ? darkFolder : lightFolder;

             function locate(file) {
