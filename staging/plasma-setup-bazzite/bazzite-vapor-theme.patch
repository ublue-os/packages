# This is needed because Bazzite by default doesn't use the Breeze Theme,
# they use the Vapor Theme which is also used on SteamOS, the theme that
# is used during the user creation with plasma-setup will also be the
# theme that is gonna be used when you first boot into the actual desktop.
# Vapor is modified breezedark, no need to change breezelight then as
# bazzite doesn't offer any additional light themes
# https://invent.kde.org/plasma/plasma-setup/-/issues/72
diff --git i/modules/prepareutil/prepareutil.cpp w/modules/prepareutil/prepareutil.cpp
index 7c9d768..0fd832b 100644
--- i/modules/prepareutil/prepareutil.cpp
+++ w/modules/prepareutil/prepareutil.cpp
@@ -93,7 +93,7 @@ void PrepareUtil::setUsingDarkTheme(bool usingDarkTheme)
 {
     // use plasma-apply-lookandfeel since it has logic for notifying the shell of changes
     if (usingDarkTheme) {
-        QProcess::execute(u"plasma-apply-lookandfeel"_s, {QStringLiteral("--apply"), QStringLiteral("org.kde.breezedark.desktop")});
+        QProcess::execute(u"plasma-apply-lookandfeel"_s, {QStringLiteral("--apply"), QStringLiteral("com.valve.vapor.desktop")});
     } else {
         QProcess::execute(u"plasma-apply-lookandfeel"_s, {QStringLiteral("--apply"), QStringLiteral("org.kde.breeze.desktop")});
     }
